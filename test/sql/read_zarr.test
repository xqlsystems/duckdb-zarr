# name: test/sql/read_zarr.test
# description: read_zarr table function — Phase 1 coverage
# group: [duckdb_zarr]

require duckdb_zarr

# ── float_baseline ─────────────────────────────────────────────────────────────
# Plain float32 data variable, dim coords (time int64, lat float64, lon float64).
# Shape (8, 6, 12) → 576 rows.

query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline.zarr');
----
576

query I
SELECT COUNT(DISTINCT lat) FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline.zarr');
----
6

query I
SELECT COUNT(DISTINCT lon) FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline.zarr');
----
12

# Coordinates span expected ranges.
query R
SELECT MIN(lat) FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline.zarr');
----
-90.000000

query R
SELECT MAX(lat) FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline.zarr');
----
90.000000

# Data column is float (non-null for plain float data with no sentinel).
query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline.zarr') WHERE temperature IS NOT NULL;
----
576

# ── read_zarr_metadata ────────────────────────────────────────────────────────

query I
SELECT COUNT(*) FROM read_zarr_metadata('test/fixtures/xarray_tutorial/float_baseline.zarr');
----
4

query TT rowsort
SELECT name, role FROM read_zarr_metadata('test/fixtures/xarray_tutorial/float_baseline.zarr');
----
lat	coord
lon	coord
temperature	data
time	coord

# ── read_zarr_groups ──────────────────────────────────────────────────────────

query I
SELECT COUNT(*) FROM read_zarr_groups('test/fixtures/xarray_tutorial/float_baseline.zarr');
----
1

query T
SELECT dims FROM read_zarr_groups('test/fixtures/xarray_tutorial/float_baseline.zarr');
----
["time","lat","lon"]

# ── air_temperature ───────────────────────────────────────────────────────────
# int16 on-disk with scale_factor=0.01 → packed-int decoding → Double column.
# Shape (2920, 25, 53) → 3,869,000 rows.

query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/air_temperature.zarr');
----
3869000

# Decoded temperatures should be reasonable (Kelvin, ~200–320 K).
query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/air_temperature.zarr')
WHERE air > 150.0 AND air < 400.0;
----
3869000

# ── unindexed_dim ─────────────────────────────────────────────────────────────
# dim_0 has no coord → synthesized 0..4 integer range.

query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/unindexed_dim.zarr');
----
120

query I
SELECT COUNT(DISTINCT dim_0) FROM read_zarr('test/fixtures/xarray_tutorial/unindexed_dim.zarr');
----
5

query II
SELECT MIN(dim_0), MAX(dim_0) FROM read_zarr('test/fixtures/xarray_tutorial/unindexed_dim.zarr');
----
0	4

# ── scalar_coord ──────────────────────────────────────────────────────────────
# hc and Vtransform are 0-dim scalars → excluded from schema.
# Schema: time, lat, temperature only.

query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/scalar_coord.zarr');
----
12

query T rowsort
SELECT name FROM read_zarr_metadata('test/fixtures/xarray_tutorial/scalar_coord.zarr')
WHERE role = 'data' OR role = 'coord';
----
lat
temperature
time

# ── sparse ────────────────────────────────────────────────────────────────────
# Only chunk [0,0] written; chunks [0,1], [1,0], [1,1] are implicit (fill_value=-9999).
# Shape (4,4), chunk (2,2) → 16 rows. fill_value=-9999 → NULL.

query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/sparse.zarr');
----
16

query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/sparse.zarr') WHERE data IS NULL;
----
12

query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/sparse.zarr') WHERE data IS NOT NULL;
----
4

# ── ersstv5 ───────────────────────────────────────────────────────────────────
# CF bounds variable (time_bnds) must be suppressed from schema.
# sst has missing_value sentinel.

query I
SELECT COUNT(*) > 0 FROM read_zarr_metadata('test/fixtures/xarray_tutorial/ersstv5.zarr')
WHERE name = 'time_bnds' AND role = 'bounds';
----
true

# time_bnds must NOT appear as a column in read_zarr output.
statement error
SELECT time_bnds FROM read_zarr('test/fixtures/xarray_tutorial/ersstv5.zarr') LIMIT 1;
----
Referenced column "time_bnds" not found

# ── basin_mask ────────────────────────────────────────────────────────────────
# missing_value=-100 (int8), no _FillValue. NULL masking via missing_value.
# Shape (45, 35) = 1575 rows. Sentinel = -100; verify exact null count and that
# non-sentinel values pass through unmasked.

query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/basin_mask.zarr')
WHERE basin IS NULL;
----
983204

query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/basin_mask.zarr')
WHERE basin IS NOT NULL;
----
1155196

# Non-sentinel values must not be nulled.
query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/basin_mask.zarr')
WHERE basin IS NOT NULL AND basin = -100;
----
0

# ── ersstv5 sst null masking ──────────────────────────────────────────────────
# sst has missing_value sentinel; verify at least some cells are masked.

query I
SELECT COUNT(*) > 0 FROM read_zarr('test/fixtures/xarray_tutorial/ersstv5.zarr')
WHERE sst IS NULL;
----
true

query I
SELECT COUNT(*) > 0 FROM read_zarr('test/fixtures/xarray_tutorial/ersstv5.zarr')
WHERE sst IS NOT NULL;
----
true

# ── rasm ──────────────────────────────────────────────────────────────────────
# rasm has 2D non-dimension coordinate arrays xc and yc (shape 205×275).
# They must be silently excluded from the row schema (aux_coords path).
# The store has exactly one dim group: (time, y, x).
# Skipped: fixture requires cftime for noleap calendar; support deferred (issue #45).

# ── multi_dim_group ───────────────────────────────────────────────────────────
# Two dim groups: surface (time,lat,lon) and atmosphere (time,level,lat,lon).
# read_zarr without selection must error.

statement error
SELECT * FROM read_zarr('test/fixtures/xarray_tutorial/multi_dim_group.zarr') LIMIT 1;
----
contains multiple dimension groups

# read_zarr_groups shows two groups.
query I
SELECT COUNT(*) FROM read_zarr_groups('test/fixtures/xarray_tutorial/multi_dim_group.zarr');
----
2

# dims= selects the surface group (time, lat, lon): 4*5*8 = 160 rows.
query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/multi_dim_group.zarr', dims='["time","lat","lon"]');
----
160

# dims= selects the atmosphere group (time, level, lat, lon): 4*3*5*8 = 480 rows.
query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/multi_dim_group.zarr', dims='["time","level","lat","lon"]');
----
480

# dims= also accepts comma-separated form.
query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/multi_dim_group.zarr', dims='time,lat,lon');
----
160

# dims= with no match → error.
statement error
SELECT * FROM read_zarr('test/fixtures/xarray_tutorial/multi_dim_group.zarr', dims='["x","y"]') LIMIT 1;
----
no dimension group matches

# ── air_temperature_gradient ─────────────────────────────────────────────────
# Mismatched chunk shapes within one dim group → bind error.

statement error
SELECT * FROM read_zarr('test/fixtures/xarray_tutorial/air_temperature_gradient.zarr') LIMIT 1;
----
chunk shape mismatch

# ── big_endian ────────────────────────────────────────────────────────────────
# Big-endian bytes codec: zarrs normalises to native; memcpy must be correct.

query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/big_endian.zarr');
----
24

query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/big_endian.zarr')
WHERE temperature IS NOT NULL;
----
24

# ── blosc_compressed ──────────────────────────────────────────────────────────
# Zarr v3 with Blosc/LZ4 codec. Shape (4,6) → 24 rows; all values non-null.
# Verifies that the Blosc codec pipeline decodes correctly end-to-end.

query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/blosc_compressed.zarr');
----
24

query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/blosc_compressed.zarr')
WHERE temperature IS NOT NULL;
----
24

query R
SELECT ROUND(SUM(temperature)::DOUBLE, 4)
FROM read_zarr('test/fixtures/xarray_tutorial/blosc_compressed.zarr');
----
-0.4564

# ── blosc_multichunk ──────────────────────────────────────────────────────────
# Zarr v3 with Blosc/LZ4 codec, shape (8,12) chunked (4,6) → 4 chunks, 96 rows.
# Exercises chunk-boundary reassembly: strides and value offsets must be correct
# across all four chunk blocks, not just the first.

query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/blosc_multichunk.zarr');
----
96

query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/blosc_multichunk.zarr')
WHERE temperature IS NOT NULL;
----
96

# Exact SUM catches any byte-offset bug that silently reads wrong values.
query R
SELECT ROUND(SUM(temperature)::DOUBLE, 4)
FROM read_zarr('test/fixtures/xarray_tutorial/blosc_multichunk.zarr');
----
0.3816

# Coord ranges span the full shape — confirms all rows from all chunks included.
query R
SELECT MIN(lat) FROM read_zarr('test/fixtures/xarray_tutorial/blosc_multichunk.zarr');
----
-90.000000

query R
SELECT MAX(lat) FROM read_zarr('test/fixtures/xarray_tutorial/blosc_multichunk.zarr');
----
90.000000

query I
SELECT COUNT(DISTINCT lat) FROM read_zarr('test/fixtures/xarray_tutorial/blosc_multichunk.zarr');
----
8

query I
SELECT COUNT(DISTINCT lon) FROM read_zarr('test/fixtures/xarray_tutorial/blosc_multichunk.zarr');
----
12

# ── projection_pushdown ───────────────────────────────────────────────────────
# Selecting a column subset must skip decompression for omitted data variables
# and still return correct values for selected columns.

# Select only the coordinate — no data variable decompression needed.
query I
SELECT COUNT(DISTINCT lat) FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline.zarr');
----
6

# Select only a data variable — coord columns still produced for row identity.
query I
SELECT COUNT(*) FROM (SELECT temperature FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline.zarr'));
----
576

# Values are correct when only one column selected from a packed-int store.
# air values decoded from int16 with scale_factor=0.01 → range 150–400 K.
query I
SELECT COUNT(*) FROM (SELECT air FROM read_zarr('test/fixtures/xarray_tutorial/air_temperature.zarr'))
WHERE air > 150.0 AND air < 400.0;
----
3869000

# Selecting a coord from a multi-var store leaves the other data var unread.
query I
SELECT COUNT(DISTINCT time) FROM read_zarr('test/fixtures/xarray_tutorial/air_temperature.zarr');
----
2920

# Project lat+lon only (both coords, no data variable) from float_baseline.
query II rowsort
SELECT MIN(lat), MAX(lat) FROM (SELECT lat, lon FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline.zarr'));
----
-90.000000	90.000000

# Single column from sparse store: NULL masking still applied.
query I
SELECT COUNT(*) FROM (SELECT data FROM read_zarr('test/fixtures/xarray_tutorial/sparse.zarr'))
WHERE data IS NULL;
----
12

# Projected lat values match full-scan values (catches column-swap bugs).
query R
SELECT MIN(lat) FROM (SELECT lat FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline.zarr'));
----
-90.000000

query R
SELECT MAX(lat) FROM (SELECT lat FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline.zarr'));
----
90.000000

# Projected lon values are independent of lat (catches lat/lon swap).
query R
SELECT MIN(lon) FROM (SELECT lon FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline.zarr'));
----
0.000000

query R
SELECT MAX(lon) FROM (SELECT lon FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline.zarr'));
----
330.000000

# Projected temperature SUM matches full-scan SUM (catches data variable column-swap).
query R
SELECT ROUND(SUM(temperature)::DOUBLE, 2)
FROM (SELECT temperature FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline.zarr'));
----
-4.270000

# Projected air SUM from packed-int store matches full-scan SUM.
query R
SELECT ROUND(SUM(air)::DOUBLE, 0)
FROM (SELECT air FROM read_zarr('test/fixtures/xarray_tutorial/air_temperature.zarr'));
----
1088175738.000000

